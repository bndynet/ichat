{
  "name": "@bndynet/ichat",
  "version": "1.0.0",
  "description": "Complete Lit 3 chat Web Component: messages + input. Register optional renderers (e.g. @bndynet/ichat-renderers) in your app.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "dependencies": {
    "@bndynet/ichat-messages": "^1.0.0",
    "@bndynet/ichat-input": "^1.0.0",
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "@bndynet/ichat-messages": "file:../chat-messages",
    "@bndynet/ichat-input": "file:../chat-input",
    "sass-embedded": "^1.86.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bndynet/ichat.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
