{
  "name": "@bndynet/chat-input",
  "version": "0.1.0",
  "description": "Lit 3 chat input Web Component: auto-resize textarea, send button, streaming cancel, and keyboard shortcuts.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "dependencies": {
    "lit": "^3.3.0"
  },
  "devDependencies": {
    "sass-embedded": "^1.86.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "license": "MIT"
}
